# HTTP listen port for the Hono webservice
PORT=3000

# Karma alerts JSON endpoint used as the source of truth
KARMA_URL=https://nmx.example.com/karma/alerts.json?q=alertname%3Dfttx%20subscriber%20offline

# Consecutive alerts are grouped together when their startsAt delta
# is less than or equal to this many seconds
THRESHOLD_SECONDS=120

# A group is considered a mass outage when its member count is
# greater than this threshold
MIN_GROUP_SIZE=15

# Maximum age of alerts (in days) to consider for clustering
MAX_ALERT_AGE_DAYS=7

# Path to the ack state file (default: ack.json in project root)
# ACK_FILE=/var/lib/gamasmon/ack.json
